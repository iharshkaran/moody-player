<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h2>Listings :</h2>
    <form method="GET" action="http://localhost:8080/listings/new">
        <button>Add+</button>
    </form>
    <ul>
        <% for(let list of listing){ %>
            <li><a href="http://localhost:8080/listings/<%= list._id %>">
                    <%= list.title %>
                </a>
            </li>
            <% } %>
    </ul>
</body>

</html>